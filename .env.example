# ================================================================================
# FILE: .env.example
# ================================================================================
#
# 🎓 FAANG-LEVEL LESSON: ENVIRONMENT VARIABLES AND SECRETS MANAGEMENT
# ──────────────────────────────────────────────────────────────────────────────
#
# WHAT IS THIS FILE?
# ──────────────────
# This is a TEMPLATE showing what your .env file should look like.
# Share this file with your team (it has no real secrets).
# NEVER share the actual .env file (it HAS real secrets).
#
# HOW TO USE:
# ─────────────
# 1. Copy this file:     copy .env.example .env
# 2. Edit the .env file with your REAL values
# 3. The .gitignore already blocks .env from being committed
#
# LOADING IN PYTHON:
# ──────────────────
# pip install python-dotenv
#
# from dotenv import load_dotenv
# import os
# load_dotenv()                              # Reads the .env file
# key = os.getenv("OPENAI_API_KEY")         # Gets the value
#
# HOW TO GET THESE API KEYS:
# ───────────────────────────
# OpenAI:  platform.openai.com → API Keys section
# Gemini:  aistudio.google.com → Get API Key
# ================================================================================

# ─────────────────────────────────────────────────────────────────────────────
# AI API KEYS (Optional — system works without these in manual mode)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# SYSTEM SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Database file location (default: pipeline.db in project root)
DATABASE_PATH=pipeline.db

# ─────────────────────────────────────────────────────────────────────────────
# QUALITY SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
# Minimum image dimensions for quality check warnings
MIN_IMAGE_WIDTH=512
MIN_IMAGE_HEIGHT=512

# Default scene duration in seconds (your AI video tool uses 6)
DEFAULT_SCENE_DURATION=6
